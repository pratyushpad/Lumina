GEMINI_API_KEY=your_key_here
# Local dev: postgres from docker-compose (docker compose up postgres), host port 5433
DATABASE_URL=postgresql+asyncpg://lumina:lumina@localhost:5433/lumina
UPLOAD_DIR=./storage/uploads
PROCESSED_DIR=./storage/processed
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Must match the embedding model's output width (MiniLM = 384) and the pgvector
# column dimension; changing it requires re-ingesting the corpus.
EMBEDDING_DIM=384
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Ingestion
CHUNKING_STRATEGY=recursive
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval pipeline (dense | sparse | hybrid_rrf; bm25 | fts; none | multi_query | hyde)
RETRIEVAL_MODE=hybrid_rrf
SPARSE_METHOD=bm25
QUERY_TRANSFORM=none
RRF_K=60
TOP_K_CANDIDATES=50
TOP_K_RERANKED=5

# Guardrails. Thresholds are calibrated in docs/eval.md — 0.25 gave 0% false
# refusals and 0% false answers on the 42+10 question eval set.
GUARDRAIL_REFUSAL_ENABLED=true
MIN_RERANK_SCORE=0.25
MIN_BIENCODER_SIM=0.25
# Regex scrub of emails/phones/SSNs/cards from chunk text at ingest. Off by
# default; limitations documented in app/services/guardrails/pii.py.
PII_SCRUB_ON_INGEST=false

LLM_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=2048

# Provider routing: comma-ordered fallback chain. "local" is any OpenAI-compatible
# endpoint — Ollama or vLLM on your own machine, or a hosted one:
#   Ollama over the LAN: LOCAL_LLM_BASE_URL=http://192.168.1.50:11434/v1
#   (on a Windows Ollama box: set OLLAMA_HOST=0.0.0.0 and open port 11434)
#   Groq (what the live deployment uses):
#     LOCAL_LLM_BASE_URL=https://api.groq.com/openai/v1
#     LOCAL_LLM_MODEL=llama-3.3-70b-versatile
#     LOCAL_LLM_API_KEY=gsk_...
LLM_PROVIDER_ORDER=local,gemini
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
# Bearer token for hosted OpenAI-compatible endpoints. Empty for local Ollama.
LOCAL_LLM_API_KEY=
LOCAL_LLM_TIMEOUT_S=120

CORS_ORIGINS=["http://localhost:5173"]
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=[".pdf",".txt",".md",".png",".jpg",".jpeg"]
RATE_LIMIT_CHAT=20/minute
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_DEFAULT=60/minute

# Seed the public demo session at startup. Production sets this true: demo_docs/
# is baked into the image, and seeding is a no-op once the DB already has it.
SEED_DEMO_ON_STARTUP=false
